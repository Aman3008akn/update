# Supabase (Auth, User Data, Reviews, Settings)
VITE_SUPABASE_URL="your-supabase-url"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Shopify Storefront API (Products, Cart, Checkout, Orders)
VITE_SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
VITE_SHOPIFY_STOREFRONT_ACCESS_TOKEN="your-storefront-access-token"

# Shopify Admin API (Admin Dashboard Only)
VITE_SHOPIFY_ADMIN_API_ACCESS_TOKEN="your-admin-access-token"

# Site
SITE_URL="https://your-site.netlify.app"
